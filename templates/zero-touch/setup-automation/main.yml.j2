---
# Setup automation for {{ lab_name }}
# Generated by Lab Foundry ({{ blueprint }} blueprint)

- name: Create inventory
  hosts: localhost
  gather_facts: false

  tasks:
    - name: Add lab nodes
      ansible.builtin.add_host:
        name: "{{ '{{ item }}' }}"
        ansible_ssh_host: "{{ '{{ item }}' }}"
        ansible_ssh_port: "{{ '{{ lookup(\"ansible.builtin.env\", \"BASTION_PORT\") }}' }}"
        ansible_ssh_user: "{{ '{{ lookup(\"ansible.builtin.env\", \"BASTION_USER\") }}' }}"
        ansible_ssh_pass: "{{ '{{ lookup(\"ansible.builtin.env\", \"BASTION_PASSWORD\") }}' }}"
        ansible_become_password: "{{ '{{ lookup(\"ansible.builtin.env\", \"BASTION_PASSWORD\") }}' }}"
        ansible_python_interpreter: /usr/libexec/platform-python
      loop:
{% for host in hosts %}
        - {{ host.name }}
{% endfor %}

- name: Configure {{ lab_name }}
  hosts: all:!localhost
  gather_facts: false

  vars:
    guid: "{{ '{{ lookup(\"ansible.builtin.env\", \"GUID\") }}' }}"
    domain: "{{ '{{ lookup(\"ansible.builtin.env\", \"DOMAIN\") }}' }}"

  tasks:
    - name: Wait for SSH connectivity
      ansible.builtin.wait_for_connection:

    - name: Set config_host variable
      ansible.builtin.set_fact:
        config_host: "{{ '{{ ansible_host }}' }}"

    - name: Create setup scripts directory
      ansible.builtin.file:
        path: /tmp/setup-scripts/
        state: directory
        mode: "0755"

    - name: Check if setup script exists
      ansible.builtin.stat:
        path: "./setup-{{ '{{ config_host }}' }}.sh"
      delegate_to: localhost
      register: r_script_test

    - name: Copy setup script to host
      ansible.builtin.copy:
        src: "./setup-{{ '{{ ansible_host }}' }}.sh"
        dest: "/tmp/setup-scripts/setup-{{ '{{ ansible_host }}' }}.sh"
        mode: "0755"
      when: r_script_test.stat.exists

    - name: Execute setup script
      ansible.builtin.shell: >-
        sh -x /tmp/setup-scripts/setup-{{ '{{ ansible_host }}' }}.sh
        > /tmp/setup-scripts/setup-{{ '{{ ansible_host }}' }}.log 2>&1
      become: true
      register: r_result
      environment:
        GUID: "{{ '{{ guid }}' }}"
        DOMAIN: "{{ '{{ domain }}' }}"
      when: r_script_test.stat.exists

    - name: Write script result to file
      ansible.builtin.copy:
        content: "{{ '{{ r_result.stdout | default(r_result.stderr) | default(r_result) }}' }}"
        dest: "/tmp/{{ '{{ ansible_host }}' }}-setup-script.out"
      delegate_to: localhost
      when: r_result is defined

    - name: Output script result
      ansible.builtin.debug:
        var: r_result
      when: r_result is defined

    - name: Fail if setup failed
      ansible.builtin.fail:
        msg: "Setup failed for {{ '{{ ansible_host }}' }}"
      when:
        - r_result is defined
        - r_result.rc != 0

# ============================================================
# Lab Foundry Health Reporter
# Automatically checks all services and reports status.
# This block is embedded by Lab Foundry. Do not remove.
# ============================================================
- name: Lab Foundry provisioning health check
  hosts: localhost
  connection: local
  gather_facts: true
  vars:
    _foundry_report_url: "{{ '{{ lookup(\"env\", \"FOUNDRY_REPORT_URL\") | default(\"\", true) }}' }}"
    _foundry_lab: "{{ lab_repo_name }}"
    _foundry_guid: "{{ '{{ lookup(\"env\", \"GUID\") | default(\"unknown\", true) }}' }}"
    _foundry_domain: "{{ '{{ lookup(\"env\", \"DOMAIN\") | default(\"unknown\", true) }}' }}"

  tasks:
{% for tab in tabs %}
    - name: "Health: {{ tab.name }}"
      ansible.builtin.uri:
        url: "{{ tab.url }}"
        method: GET
        validate_certs: false
        status_code: [200, 301, 302, 303, 401, 403]
        timeout: 15
      register: _check_{{ loop.index }}
      ignore_errors: true

{% endfor %}
    - name: Build health report
      ansible.builtin.set_fact:
        _foundry_report:
          lab: "{{ '{{ _foundry_lab }}' }}"
          guid: "{{ '{{ _foundry_guid }}' }}"
          timestamp: "{{ '{{ ansible_date_time.iso8601 }}' }}"
          stage: provisioning
          checks:
{% for tab in tabs %}
            - name: "{{ tab.name }}"
              status: "{{ '{{ _check_' ~ loop.index ~ '.status | default(-1) }}' }}"
              ok: "{{ '{{ not (_check_' ~ loop.index ~ '.failed | default(true)) }}' }}"
{% endfor %}

    - name: Display health report
      ansible.builtin.debug:
        msg: |
          Lab Foundry Health Report: {{ '{{ _foundry_lab }}' }} ({{ '{{ _foundry_guid }}' }})
          {{ '{% for c in _foundry_report.checks %}' }}
          {{ '{{ \"PASS\" if c.ok else \"FAIL\" }}' }}: {{ '{{ c.name }}' }} (HTTP {{ '{{ c.status }}' }})
          {{ '{% endfor %}' }}

    - name: Send report to webhook
      ansible.builtin.uri:
        url: "{{ '{{ _foundry_report_url }}' }}"
        method: POST
        body_format: json
        body: "{{ '{{ _foundry_report }}' }}"
        status_code: [200, 201, 202]
        timeout: 10
      when: _foundry_report_url | length > 0
      ignore_errors: true
