---
# Setup automation for {{ lab_name }}
# Generated by Lab Foundry ({{ blueprint }} blueprint)

- name: Configure {{ lab_name }}
  hosts: all
  become: true
  gather_facts: true

  vars:
    module_dir: "{{ '{{ MODULE_DIR }}' }}"
    bastion_host: "{{ '{{ BASTION_HOST }}' }}"
    bastion_user: "{{ '{{ BASTION_USER }}' }}"
    bastion_password: "{{ '{{ BASTION_PASSWORD }}' }}"

  tasks:
{% for host in hosts %}
    - name: Run setup for {{ host.name }}
      ansible.builtin.script: "{{ '{{ module_dir }}' }}/setup-{{ host.name }}.sh"
      args:
        chdir: /tmp
      delegate_to: {{ host.name }}
      register: setup_{{ host.name | replace('-', '_') }}
      retries: 3
      delay: 10
      until: setup_{{ host.name | replace('-', '_') }}.rc == 0

{% endfor %}

# ============================================================
# Lab Foundry Health Reporter
# Automatically checks all services and reports status.
# This block is embedded by Lab Foundry. Do not remove.
# ============================================================
- name: Lab Foundry provisioning health check
  hosts: localhost
  connection: local
  gather_facts: true
  vars:
    _foundry_report_url: "{{ '{{ lookup(\"env\", \"FOUNDRY_REPORT_URL\") | default(\"\", true) }}' }}"
    _foundry_lab: "{{ lab_repo_name }}"
    _foundry_guid: "{{ '{{ lookup(\"env\", \"GUID\") | default(\"unknown\", true) }}' }}"
    _foundry_domain: "{{ '{{ lookup(\"env\", \"DOMAIN\") | default(\"unknown\", true) }}' }}"

  tasks:
{% for tab in tabs %}
    - name: "Health: {{ tab.name }}"
      ansible.builtin.uri:
        url: "{{ tab.url }}"
        method: GET
        validate_certs: false
        status_code: [200, 301, 302, 303, 401, 403]
        timeout: 15
      register: _check_{{ loop.index }}
      ignore_errors: true

{% endfor %}
    - name: Build health report
      ansible.builtin.set_fact:
        _foundry_report:
          lab: "{{ '{{ _foundry_lab }}' }}"
          guid: "{{ '{{ _foundry_guid }}' }}"
          timestamp: "{{ '{{ ansible_date_time.iso8601 }}' }}"
          stage: provisioning
          checks:
{% for tab in tabs %}
            - name: "{{ tab.name }}"
              status: "{{ '{{ _check_' ~ loop.index ~ '.status | default(-1) }}' }}"
              ok: "{{ '{{ not (_check_' ~ loop.index ~ '.failed | default(true)) }}' }}"
{% endfor %}

    - name: Display health report
      ansible.builtin.debug:
        msg: |
          Lab Foundry Health Report: {{ '{{ _foundry_lab }}' }} ({{ '{{ _foundry_guid }}' }})
          {{ '{% for c in _foundry_report.checks %}' }}
          {{ '{{ \"PASS\" if c.ok else \"FAIL\" }}' }}: {{ '{{ c.name }}' }} (HTTP {{ '{{ c.status }}' }})
          {{ '{% endfor %}' }}

    - name: Send report to webhook
      ansible.builtin.uri:
        url: "{{ '{{ _foundry_report_url }}' }}"
        method: POST
        body_format: json
        body: "{{ '{{ _foundry_report }}' }}"
        status_code: [200, 201, 202]
        timeout: 10
      when: _foundry_report_url | length > 0
      ignore_errors: true
