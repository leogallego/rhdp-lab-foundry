---
# Runtime automation for {{ lab_name }}
# Generated by Lab Foundry ({{ blueprint }} blueprint)
#
# Called by Showroom for each module with:
#   MODULE_DIR: path to the module directory
#   MODULE_STAGE: setup | solve | validation

- name: Run module automation
  hosts: all
  become: true
  gather_facts: false

  vars:
    module_dir: "{{ '{{ lookup(\"env\", \"MODULE_DIR\") }}' }}"
    module_stage: "{{ '{{ lookup(\"env\", \"MODULE_STAGE\") | default(\"setup\") }}' }}"
    job_info_dir: "{{ '{{ lookup(\"env\", \"JOB_INFO_DIR\") | default(\"/tmp\") }}' }}"

  tasks:
    - name: "Run {{ '{{ module_stage }}' }} script for {{ '{{ module_dir | basename }}' }}"
      ansible.builtin.script: "{{ '{{ module_dir }}' }}/{{ '{{ module_stage }}' }}-control.sh"
      args:
        chdir: /tmp
      register: module_result
      ignore_errors: true

    - name: Display result
      ansible.builtin.debug:
        msg: "{{ '{{ module_stage }}' }} {{ '{{ \"passed\" if module_result.rc == 0 else \"FAILED (rc=\" + module_result.rc | string + \")\" }}' }}"

# ============================================================
# Lab Foundry Module Reporter
# ============================================================
- name: Report module result
  hosts: localhost
  connection: local
  gather_facts: false
  vars:
    _foundry_report_url: "{{ '{{ lookup(\"env\", \"FOUNDRY_REPORT_URL\") | default(\"\", true) }}' }}"

  tasks:
    - name: Send module report
      ansible.builtin.uri:
        url: "{{ '{{ _foundry_report_url }}' }}"
        method: POST
        body_format: json
        body:
          lab: "{{ lab_repo_name }}"
          guid: "{{ '{{ lookup(\"env\", \"GUID\") | default(\"unknown\") }}' }}"
          stage: "{{ '{{ hostvars[groups[\"all\"][0]].module_stage | default(\"unknown\") }}' }}"
          module: "{{ '{{ hostvars[groups[\"all\"][0]].module_dir | default(\"\") | basename }}' }}"
          result: "{{ '{{ hostvars[groups[\"all\"][0]].module_result.rc | default(-1) }}' }}"
          timestamp: "{{ '{{ now() }}' }}"
        status_code: [200, 201, 202]
        timeout: 10
      when: _foundry_report_url | length > 0
      ignore_errors: true
