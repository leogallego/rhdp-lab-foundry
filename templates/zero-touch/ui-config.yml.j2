---
# Showroom UI Configuration for {{ lab_name }}
# Generated by Lab Foundry
#
# external: false = Showroom nginx proxies the tab, stripping
#   X-Frame-Options headers so it loads in the iframe.
# external: true = Opens in the iframe directly (may fail if
#   the service sets X-Frame-Options: DENY).

antora:
  name: modules
  dir: www

  modules:
{% for module in modules %}
    - name: {{ module.id }}
      label: "{{ module.title }}"
      solveButton: {{ module.solve | default('true') }}
{% endfor %}

tabs:
{% for tab in tabs | default([]) %}
  - name: {{ tab.name }}
    url: {{ tab.url }}
    external: {{ tab.external | default('false') }}
{% endfor %}
  - name: Terminal
    url: terminal
    type: terminal
