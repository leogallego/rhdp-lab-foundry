---
# Lab: {{ lab_name }}
# Generated by Lab Foundry ({{ blueprint }} blueprint)
#
# RHDP runner format rules:
# - VM memory uses G (e.g., 16G), container memory uses Gi (e.g., 2Gi)
# - Container environment must be a flat dict (runner uses dict2items)
# - Container ports must be objects with name/containerPort/protocol
# - Container services use ports as list of {port, protocol, targetPort}
# - Containers do NOT use routes (RHDP runner handles routing from services)
# - Only VMs use routes with tls_termination
# - Firewall: flat indentation, egress should mirror ingress

{% if virtualmachines is defined %}
virtualmachines:
{% for vm in virtualmachines %}
  - name: {{ vm.name }}
    image: {{ vm.image }}
    memory: {{ vm.memory | default('4Gi') }}
    cores: {{ vm.cores | default(2) }}
    image_size: {{ vm.image_size | default('30Gi') }}
{% if vm.services is defined %}
    services:
{% for svc in vm.services %}
      - name: {{ svc.name }}
        ports:
          - port: {{ svc.port }}
            protocol: {{ svc.protocol | default('TCP') }}
            targetPort: {{ svc.port }}
            name: {{ svc.name }}
{% endfor %}
{% endif %}
{% if vm.routes is defined %}
    routes:
{% for route in vm.routes %}
      - name: {{ route.name }}
        host: {{ route.host | default(route.name) }}
        service: {{ route.service }}
        targetPort: {{ route.target_port }}
        tls: true
        tls_termination: {{ route.tls | default('Edge') }}
{% endfor %}
{% endif %}
{% if vm.userdata is defined %}
    userdata: |-
{{ vm.userdata | indent(6, true) }}
{% endif %}
{% if vm.tags is defined %}
    tags:
{% for tag in vm.tags %}
      - key: {{ tag.key }}
        value: {{ tag.value }}
{% endfor %}
{% endif %}
{% if vm.networks is defined %}
    networks:
{% for net in vm.networks %}
      - {{ net }}
{% endfor %}
{% endif %}
{% endfor %}
{% endif %}

{% if containers is defined %}
containers:
{% for container in containers %}
  - name: {{ container.name }}
    image: {{ container.image }}
{% if container.ports is defined %}
    ports:
{% for port in container.ports %}
      - name: {{ port.name | default(container.name) }}
        containerPort: {{ port.containerPort | default(port) }}
        protocol: {{ port.protocol | default('TCP') }}
{% endfor %}
{% endif %}
{% if container.environment is defined %}
    environment:
{% for key, value in container.environment.items() %}
      {{ key }}: "{{ value }}"
{% endfor %}
{% endif %}
{% if container.volumeMounts is defined %}
    volumeMounts:
{% for vol in container.volumeMounts %}
      - name: {{ vol.name }}
        mountPath: {{ vol.mountPath }}
{% endfor %}
{% endif %}
{% if container.volumes is defined %}
    volumes:
{% for vol in container.volumes %}
      - name: {{ vol.name }}
        emptyDir: {}
{% endfor %}
{% endif %}
{% if container.commands is defined %}
    commands:
{% for cmd in container.commands %}
      - {{ cmd }}
{% endfor %}
{% endif %}
{% if container.memory is defined %}
    memory: {{ container.memory }}
{% endif %}
{% if container.services is defined %}
    services:
{% for svc in container.services %}
      - name: {{ svc.name }}
        ports:
{% for port in svc.ports | default([{'port': svc.port, 'protocol': 'TCP', 'targetPort': svc.port}]) %}
          - port: {{ port.port }}
            protocol: {{ port.protocol | default('TCP') }}
            targetPort: {{ port.targetPort | default(port.port) }}
{% endfor %}
{% endfor %}
{% endif %}
{% endfor %}
{% endif %}
